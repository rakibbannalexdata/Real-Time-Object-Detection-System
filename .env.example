# ─────────────────────────────────────────────────────────────────────────────
# Environment Configuration for Object Detection System
# Copy this file to .env and adjust values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# App metadata
APP_NAME="Real-Time Object Detection System"
APP_VERSION="1.0.0"
DEBUG=false

# Logging
LOG_LEVEL=INFO

# API
API_PREFIX=/api/v1
ALLOWED_ORIGINS=["*"]

# Rate limiting (per IP per minute)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# YOLO Model
MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# Image processing
MAX_IMAGE_SIZE=1280

# Video processing
VIDEO_FRAME_SKIP=1
MAX_VIDEO_FRAMES=500
